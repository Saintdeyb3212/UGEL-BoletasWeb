@model UGEL_BoletasWeb.Models.ViewModels.FiltroConsultaViewModel
@{
    ViewData["Title"] = "Consulta Detallada de Planillas";
}

<div class="container mt-4">
    <div class="row mb-4">
        <div class="col-12">
            <h2 class="text-primary border-bottom pb-2 fw-bold">
                <i class="bi bi-shield-check"></i> Módulo de Pagaduría - Consulta de Historial
            </h2>
        </div>
    </div>

    <div class="card shadow-sm border-0 mb-4 bg-white">
        <div class="card-body p-4">
            <form asp-controller="Pagaduria" asp-action="Consultar" method="post" class="row g-3 align-items-end">
                <div class="col-md-5">
                    <label asp-for="DNI" class="form-label fw-bold text-secondary"><i class="bi bi-card-text"></i> Documento de Identidad (DNI)</label>
                    <input asp-for="DNI" class="form-control form-control-lg border-primary" placeholder="Ingrese 8 dígitos" maxlength="8" required />
                </div>
                <div class="col-md-4">
                    <label asp-for="Anio" class="form-label fw-bold text-secondary"><i class="bi bi-calendar-event"></i> Periodo Anual</label>
                    <select asp-for="Anio" class="form-select form-select-lg border-primary" required>
                        <option value="">Seleccione el año...</option>
                        <option value="2026">2026</option>
                        <option value="2025">2025</option>
                        <option value="2024">2024</option>
                        <option value="2023">2023</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <button type="submit" class="btn btn-primary btn-lg w-100 fw-bold">
                        <i class="bi bi-search"></i> Buscar Registros
                    </button>
                </div>
            </form>
        </div>
    </div>

    @if (ViewBag.MensajeAviso != null)
    {
        <div class="alert alert-warning border-0 shadow-sm fw-bold">
            <i class="bi bi-exclamation-circle-fill"></i> @ViewBag.MensajeAviso
        </div>
    }

    @if (Model.Resultados != null && Model.Resultados.Any())
    {
        <div class="mb-3">
            <h4 class="text-secondary fw-bold">
                <i class="bi bi-person-badge"></i> Expediente Digital: <span class="text-dark">@Model.Resultados.First().Apellidos, @Model.Resultados.First().Nombres</span>
            </h4>
        </div>

        <div class="accordion shadow-sm" id="accordionBoletas">
            @for (int i = 0; i < Model.Resultados.Count; i++)
            {
                var boleta = Model.Resultados[i];
                var collapseId = $"collapse_{i}";
                var headingId = $"heading_{i}";

                <div class="accordion-item border-0 mb-3 shadow-sm rounded overflow-hidden">
                    <h2 class="accordion-header" id="@headingId">
                        <button class="accordion-button collapsed bg-white text-dark py-3" type="button" data-bs-toggle="collapse" data-bs-target="#@collapseId" aria-expanded="false" aria-controls="@collapseId">
                            <div class="row w-100 align-items-center text-center text-md-start">
                                <div class="col-md-2 col-6 mb-2 mb-md-0">
                                    <span class="badge bg-primary fs-6 px-3">Periodo: @boleta.Mes-@boleta.Anio</span>
                                </div>
                                <div class="col-md-4 col-6 mb-2 mb-md-0 fw-bold text-secondary text-truncate">
                                    Cargo: <span class="text-dark fw-normal">@boleta.Cargo</span>
                                </div>
                                <div class="col-md-2 col-4 text-success fw-bold">
                                    Ingresos: S/ @boleta.TotalIngresos.ToString("N2")
                                </div>
                                <div class="col-md-2 col-4 text-danger fw-bold">
                                    Dsctos: S/ @boleta.TotalDescuentos.ToString("N2")
                                </div>
                                <div class="col-md-2 col-4 fw-bold text-primary fs-5">
                                    Líquido: S/ @boleta.MontoLiquido.ToString("N2")
                                </div>
                            </div>
                        </button>
                    </h2>

                    <div id="@collapseId" class="accordion-collapse collapse" aria-labelledby="@headingId" data-bs-parent="#accordionBoletas">
                        <div class="accordion-body bg-light border-top p-4">

                            <div class="row g-3 mb-4 text-secondary fs-7 bg-white p-3 rounded shadow-sm border-start border-4 border-info">
                                <div class="col-md-3 col-6">
                                    <strong><i class="bi bi-bank"></i> Cuenta Bancaria:</strong> <span class="text-dark">@boleta.CuentaBancaria</span>
                                </div>
                                <div class="col-md-3 col-6">
                                    <strong><i class="bi bi-file-earmark-text"></i> Tipo Pensionista:</strong> <span class="text-dark">@boleta.TipoPensionista</span>
                                </div>
                                <div class="col-md-3 col-6">
                                    <strong><i class="bi bi-journal-text"></i> Régimen / Ley:</strong> <span class="text-dark">@boleta.TipoPension</span>
                                </div>
                                <div class="col-md-3 col-6 bg-warning bg-opacity-10 rounded px-2">
                                    <strong class="text-warning-dark"><i class="bi bi-calculator"></i> M. Imponible:</strong>
                                    <span class="text-dark fw-bold">S/ @boleta.MontoImponible.ToString("N2")</span>
                                </div>
                            </div>

                            <div class="row g-4">
                                <div class="col-md-6">
                                    <div class="card h-100 border-0 shadow-sm">
                                        <div class="card-header bg-success bg-opacity-10 text-success fw-bold border-0">
                                            <i class="bi bi-plus-circle-fill"></i> DESGLOSE DE INGRESOS (REMUNERACIONES)
                                        </div>
                                        <div class="card-body p-0">
                                            <table class="table table-sm table-hover table-striped mb-0">
                                                <thead class="table-light">
                                                    <tr>
                                                        <th class="ps-3">Concepto / Código</th>
                                                        <th class="text-end pe-3">Monto</th>
                                                    </tr>
                                                </thead>
                                                <tbody>
                                                    @foreach (var detalle in boleta.Detalles.Where(d => d.TipoConcepto == "I"))
                                                    {
                                                        <tr>
                                                            <td class="ps-3 text-secondary">@detalle.CodigoConcepto</td>
                                                            <td class="text-end pe-3 text-success fw-bold">S/ @detalle.Monto.ToString("N2")</td>
                                                        </tr>
                                                    }
                                                </tbody>
                                                <tfoot class="table-light fw-bold border-top">
                                                    <tr>
                                                        <td class="ps-3">TOTAL INGRESOS:</td>
                                                        <td class="text-end pe-3 text-success">S/ @boleta.TotalIngresos.ToString("N2")</td>
                                                    </tr>
                                                </tfoot>
                                            </table>
                                        </div>
                                    </div>
                                </div>

                                <div class="col-md-6">
                                    <div class="card h-100 border-0 shadow-sm">
                                        <div class="card-header bg-danger bg-opacity-10 text-danger fw-bold border-0">
                                            <i class="bi bi-dash-circle-fill"></i> DESGLOSE DE DESCUENTOS
                                        </div>
                                        <div class="card-body p-0">
                                            <table class="table table-sm table-hover table-striped mb-0">
                                                <thead class="table-light">
                                                    <tr>
                                                        <th class="ps-3">Concepto / Código</th>
                                                        <th class="text-end pe-3">Monto</th>
                                                    </tr>
                                                </thead>
                                                <tbody>
                                                    @foreach (var detalle in boleta.Detalles.Where(d => d.TipoConcepto == "D"))
                                                    {
                                                        <tr>
                                                            <td class="ps-3 text-secondary">@detalle.CodigoConcepto</td>
                                                            <td class="text-end pe-3 text-danger fw-bold">S/ @detalle.Monto.ToString("N2")</td>
                                                        </tr>
                                                    }
                                                </tbody>
                                                <tfoot class="table-light fw-bold border-top">
                                                    <tr>
                                                        <td class="ps-3">TOTAL DESCUENTOS:</td>
                                                        <td class="text-end pe-3 text-danger">S/ @boleta.TotalDescuentos.ToString("N2")</td>
                                                    </tr>
                                                </tfoot>
                                            </table>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <div class="row mt-4 align-items-center">
                                <div class="col-md-8 text-muted fs-8">
                                    <i class="bi bi-info-circle"></i> Registrado en el sistema por <strong>@boleta.UsuarioCreacion</strong> el @boleta.FechaCreacion.ToString("dd/MM/yyyy HH:mm") UTC.
                                </div>
                                <div class="col-md-4 text-end">
                                    <button class="btn btn-danger fw-bold w-100 shadow-sm">
                                        <i class="bi bi-file-earmark-pdf-fill"></i> Exportar Documento PDF
                                    </button>
                                </div>
                            </div>

                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>