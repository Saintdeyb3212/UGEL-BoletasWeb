@model UGEL_BoletasWeb.Models.ViewModels.FiltroConsultaViewModel
@{
    ViewData["Title"] = "Consulta de Boletas";
}

<div class="reportes-card mb-3">
    <div class="reportes-header">
        <h2 class="reportes-title">
            <i class="bi bi-file-earmark-text me-2"></i> Búsqueda de Planillas
        </h2>
    </div>

    <div class="p-3 bg-white">
        <form asp-controller="Pagaduria" asp-action="Consultar" method="get">

            <div class="row g-2">
                <div class="col-xl-3 col-lg-4 col-md-6">
                    <div class="form-group-premium">
                        <label asp-for="DNI" class="form-label-premium">Documento D.N.I.</label>
                        <input asp-for="DNI" class="form-control-premium" placeholder="Ingrese 8 dígitos" maxlength="8" required />
                    </div>
                </div>
                <div class="col-xl-2 col-lg-3 col-md-6">
                    <div class="form-group-premium">
                        <label asp-for="Anio" class="form-label-premium">Año Fiscal</label>
                        <input asp-for="Anio" type="number" class="form-control-premium fw-bold text-center" min="1980" max="2099" required />
                    </div>
                </div>
                <div class="col-xl-3 col-lg-5 col-md-12">
                    <div class="form-group-premium">
                        <label asp-for="Mes" class="form-label-premium">Mes de Planilla</label>
                        <select asp-for="Mes" class="form-control-premium">
                            <option value="">-- Todos los meses --</option>
                            <option value="01">01 - Enero</option>
                            <option value="02">02 - Febrero</option>
                            <option value="03">03 - Marzo</option>
                            <option value="04">04 - Abril</option>
                            <option value="05">05 - Mayo</option>
                            <option value="06">06 - Junio</option>
                            <option value="07">07 - Julio</option>
                            <option value="08">08 - Agosto</option>
                            <option value="09">09 - Setiembre</option>
                            <option value="10">10 - Octubre</option>
                            <option value="11">11 - Noviembre</option>
                            <option value="12">12 - Diciembre</option>
                        </select>
                    </div>
                </div>
                <div class="col-xl-2 col-lg-6 col-md-6">
                    <div class="form-group-premium">
                        <button type="submit" class="btn-search w-100">
                            <i class="bi bi-search me-2"></i> BUSCAR
                        </button>
                    </div>
                </div>
                <div class="col-xl-2 col-lg-6 col-md-6">
                    <div class="form-group-premium">
                        <a asp-action="Consultar" class="btn-clear w-100">LIMPIAR</a>
                    </div>
                </div>
            </div>
        </form>
    </div>
</div>

@if (ViewBag.MensajeAviso != null)
{
    <div class="alert alert-warning py-2 px-3 fw-bold mb-3 border-0 shadow-sm" style="font-size: 0.85rem;">
        <i class="bi bi-exclamation-triangle-fill me-2"></i> @ViewBag.MensajeAviso
    </div>
}

@if (Model != null && Model.Resultados != null && Model.Resultados.Any())
{
    @foreach (var boleta in Model.Resultados)
    {
        <div class="reportes-card mb-4">
            <div class="reportes-header py-2 px-3 bg-light border-bottom">
                <div class="d-flex align-items-center">
                    <div class="bg-primary text-white rounded px-2 py-1 me-3 fw-bold shadow-sm" style="font-size: 0.8rem;">@boleta.Mes - @boleta.Anio</div>
                    <h6 class="mb-0 fw-bold text-uppercase text-dark">@boleta.Apellidos, @boleta.Nombres</h6>
                </div>
                <a asp-controller="Pagaduria" asp-action="DescargarBoletaPdf" asp-route-id="@boleta.Id" class="btn-export" target="_blank">
                    <i class="bi bi-file-earmark-pdf-fill"></i> EXPORTAR
                </a>
            </div>

            <div class="p-3">
                <table class="tabla-cabecera-datos">
                    <tbody>
                        <tr>
                            <td class="lbl-celda">D.N.I.</td>
                            <td class="val-celda font-monospace fw-bold">@boleta.DNI</td>
                            <td class="lbl-celda">Cargo Actual</td>
                            <td class="val-celda text-primary fw-bold text-uppercase">@boleta.Cargo</td>
                        </tr>
                        <tr>
                            <td class="lbl-celda">Fec. Nacimiento</td>
                            <td class="val-celda">@boleta.FechaNacimiento</td>
                            <td class="lbl-celda">Tipo Pensionista</td>
                            <td class="val-celda text-uppercase">@boleta.TipoPensionista</td>
                        </tr>
                        <tr>
                            <td class="lbl-celda">Tiempo Servicio</td>
                            <td class="val-celda">@boleta.TiempoServicio</td>
                            <td class="lbl-celda">Régimen Legal</td>
                            <td class="val-celda text-uppercase">@boleta.TipoPension</td>
                        </tr>
                        <tr>
                            <td class="lbl-celda">Cód. EsSalud</td>
                            <td class="val-celda font-monospace">@boleta.CodigoEsSalud</td>
                            <td class="lbl-celda">Niv.Mag/G.Ocup</td>
                            <td class="val-celda">@boleta.NivelMagisterial</td>
                        </tr>
                        <tr>
                            <td class="lbl-celda">Cta. Ahorros</td>
                            <td class="val-celda font-monospace">@boleta.CuentaBancaria</td>
                            <td class="lbl-celda">Fechas Registr.</td>
                            <td class="val-celda">@boleta.FechasRegistro</td>
                        </tr>
                        <tr>
                            <td class="lbl-celda">Leyenda Perm.</td>
                            <td colspan="3" class="val-celda text-wrap">@(!string.IsNullOrEmpty(boleta.LeyendaPermanente) ? boleta.LeyendaPermanente : "-")</td>
                        </tr>
                        <tr>
                            <td class="lbl-celda">Leyenda Mensual</td>
                            <td colspan="3" class="val-celda text-wrap">@(!string.IsNullOrEmpty(boleta.LeyendaMensual) ? boleta.LeyendaMensual : "-")</td>
                        </tr>
                    </tbody>
                </table>

                <div class="row g-3">
                    <div class="col-lg-7">
                        <div class="border rounded px-3 py-2 h-100">
                            <h6 class="fw-bold mb-2 pb-1 border-bottom" style="color: var(--success-green); font-size: 0.8rem;"><i class="bi bi-plus-circle-fill me-1"></i> INGRESOS</h6>
                            <div class="multi-column-list">
                                @{
                                    var ingresos = boleta.Detalles.Where(d => d.TipoConcepto == "I").ToList();
                                }
                                @if (ingresos.Any())
                                {
                                    foreach (var i in ingresos)
                                    {
                                        <div class="item-concepto">
                                            <span class="text-secondary font-monospace">@i.CodigoConcepto</span>
                                            <span class="fw-bold text-success font-monospace">@i.Monto.ToString("N2")</span>
                                        </div>
                                    }
                                }
                                else
                                {
                                    <div class="text-muted text-center p-1" style="font-size: 0.8rem;">No registra</div>
                                }
                            </div>
                        </div>
                    </div>

                    <div class="col-lg-5">
                        <div class="border rounded px-3 py-2 h-100">
                            <h6 class="fw-bold mb-2 pb-1 border-bottom" style="color: var(--danger-red); font-size: 0.8rem;"><i class="bi bi-dash-circle-fill me-1"></i> DESCUENTOS</h6>
                            <div class="multi-column-list" style="column-count: 1;">
                                @{
                                    var descuentos = boleta.Detalles.Where(d => d.TipoConcepto == "D").ToList();
                                }
                                @if (descuentos.Any())
                                {
                                    foreach (var d in descuentos)
                                    {
                                        <div class="item-concepto">
                                            <span class="text-secondary font-monospace">@d.CodigoConcepto</span>
                                            <span class="fw-bold text-danger font-monospace">@d.Monto.ToString("N2")</span>
                                        </div>
                                    }
                                }
                                else
                                {
                                    <div class="text-muted text-center p-1" style="font-size: 0.8rem;">No registra</div>
                                }
                            </div>
                        </div>
                    </div>
                </div>

                <div class="row mt-3 pt-3 border-top g-2">
                    <div class="col-xl-3 col-6">
                        <div class="p-2 bg-light rounded border text-center">
                            <div class="text-muted fw-bold text-uppercase" style="font-size: 0.65rem;">M. Imponible</div>
                            <div class="fw-bold text-dark mt-1" style="font-size: 1.1rem;">S/ @boleta.MontoImponible.ToString("N2")</div>
                        </div>
                    </div>
                    <div class="col-xl-3 col-6">
                        <div class="p-2 rounded border text-center" style="background-color: #f0fdf4; border-color: #d1fae5;">
                            <div class="fw-bold text-uppercase" style="font-size: 0.65rem; color: #047857;">T. Ingresos</div>
                            <div class="fw-bold mt-1" style="font-size: 1.1rem; color: #065f46;">S/ @boleta.TotalIngresos.ToString("N2")</div>
                        </div>
                    </div>
                    <div class="col-xl-3 col-6">
                        <div class="p-2 rounded border text-center" style="background-color: #fef2f2; border-color: #fee2e2;">
                            <div class="fw-bold text-uppercase" style="font-size: 0.65rem; color: #b91c1c;">T. Descuentos</div>
                            <div class="fw-bold mt-1" style="font-size: 1.1rem; color: #991b1b;">S/ @boleta.TotalDescuentos.ToString("N2")</div>
                        </div>
                    </div>
                    <div class="col-xl-3 col-6">
                        <div class="p-2 rounded shadow-sm text-center" style="background-color: var(--primary-dark); color: white;">
                            <div class="text-white-50 fw-bold text-uppercase" style="font-size: 0.65rem;">Líquido a Pagar</div>
                            <div class="fw-bold mt-1" style="font-size: 1.25rem;">S/ @boleta.MontoLiquido.ToString("N2")</div>
                        </div>
                    </div>
                </div>

            </div>
        </div>
    }
}