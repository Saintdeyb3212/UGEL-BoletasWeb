<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>Consulta de Boletas - UGEL Concepción</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/ConsultasReportes.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/AjustesGenerales.css" asp-append-version="true" />
</head>
<body>
    <div class="app-layout">

        <aside class="sidebar">
            <div class="sidebar-header">
                <div class="mb-3 d-flex align-items-center justify-content-center bg-white shadow-sm" style="width: 75px; height: 75px; border-radius: 50%; padding: 4px; overflow: hidden;">
                    <img src="~/img/logo-ugel.png" alt="Escudo UGEL" style="width: 100%; height: 100%; object-fit: contain;" />
                </div>

                <h4 class="fw-bold mb-0 text-white tracking-wide text-center">UGEL CONCEPCIÓN</h4>
                <span class="text-white-50" style="font-size: 0.8rem; font-weight: 500; letter-spacing: 1px;">SISTEMA DIGITAL DE BOLETAS</span>
            </div>

            <nav class="sidebar-nav">
                <a asp-controller="Pagaduria" asp-action="Consultar" class="nav-item">
                    <i class="bi bi-search nav-icon"></i>
                    <span>Consulta de Boletas</span>
                </a>

                @if (User.IsInRole("Administrador"))
                {
                    <a asp-controller="Administrador" asp-action="Ajustes" class="nav-item">
                        <i class="bi bi-gear-fill nav-icon"></i>
                        <span>Ajustes Generales</span>
                    </a>
                }
            </nav>

            <div class="sidebar-footer">
                <div class="mb-3 px-2 text-center">
                    <p class="text-white-50 mb-1" style="font-size: 0.8rem;">Usuario Activo:</p>

                    <p class="text-white fw-bold mb-0 text-uppercase" style="font-size: 0.9rem;">
                        @User.Identity?.Name
                    </p>

                    <span class="badge rounded-pill bg-light text-dark mt-1 shadow-sm" style="font-size: 0.65rem; font-weight: 700;">
                        @(User.Claims.FirstOrDefault(c => c.Type == System.Security.Claims.ClaimTypes.Role)?.Value)
                    </span>
                </div>

                <a asp-controller="Autenticacion" asp-action="CerrarSesion" class="btn-logout">
                    <i class="bi bi-box-arrow-right"></i> Cerrar Sesión
                </a>
            </div>
        </aside>

        <main class="main-content" style="padding: 1rem;">
            @RenderBody()
        </main>

    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    <script>
        $(document).ready(function() {
        var path = window.location.pathname;
        $('.sidebar-nav .nav-item').each(function() {
        if ($(this).attr('href') === path) {
        $(this).addClass('activo');
        }
        });
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>