<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Sistema Integral UGEL</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/ConsultasReportes.css" asp-append-version="true" />
</head>
<body>
    <div class="app-layout">

        <aside class="sidebar">
            <div class="sidebar-header">
                <div class="bg-white text-primary rounded-circle d-flex align-items-center justify-content-center shadow-lg mb-3" style="width: 60px; height: 60px; color: #0a4b7d !important;">
                    <i class="bi bi-bank2 fs-2"></i>
                </div>
                <h4 class="fw-bold mb-0 text-white tracking-wide text-center">UGEL CONCEPCIÓN</h4>
                <span class="text-white-50" style="font-size: 0.8rem; font-weight: 500; letter-spacing: 1px;">SISTEMA DIGITAL</span>
            </div>

            <nav class="sidebar-nav">
                <a asp-controller="Pagaduria" asp-action="Consultar" class="nav-item">
                    <i class="bi bi-search nav-icon"></i>
                    <span>Consulta de Boletas</span>
                </a>

                @if (User.IsInRole("Administrador"))
                {
                    <a asp-controller="Administrador" asp-action="Ajustes" class="nav-item">
                        <i class="bi bi-gear-fill nav-icon"></i>
                        <span>Ajustes Generales</span>
                    </a>
                }
            </nav>

            <div class="sidebar-footer">
                <div class="mb-3 px-2 text-center">
                    <p class="text-white-50 mb-1" style="font-size: 0.8rem;">Usuario Activo:</p>
                    <p class="text-white fw-bold mb-0" style="font-size: 0.9rem;">Administrador Principal</p>
                </div>
                <a asp-controller="Autenticacion" asp-action="IniciarSesion" class="btn-logout">
                    <i class="bi bi-box-arrow-right"></i> Cerrar Sesión
                </a>
            </div>
        </aside>

        <main class="main-content" style="padding: 2rem;">
            @RenderBody()
        </main>

    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    <script>
        $(document).ready(function() {
        var path = window.location.pathname;
        $('.sidebar-nav .nav-item').each(function() {
        if ($(this).attr('href') === path) {
        $(this).addClass('activo');
        }
        });
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>