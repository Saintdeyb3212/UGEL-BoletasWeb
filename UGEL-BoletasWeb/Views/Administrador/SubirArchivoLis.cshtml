@{
    ViewData["Title"] = "Gestión de Planillas LIS";
}

<div class="row justify-content-center align-items-center">
    <div class="col-xl-6 col-lg-8 col-md-10">

        <div class="text-center mb-5 mt-3">
            <div class="d-inline-flex align-items-center justify-content-center bg-primary bg-opacity-10 text-primary rounded-circle mb-3 p-4 shadow-sm" style="width: 80px; height: 80px;">
                <i class="bi bi-cloud-arrow-up-fill fs-1"></i>
            </div>
            <h2 class="fw-bold text-dark mb-1">Importador de Planillas Mensuales</h2>
            <p class="text-muted fs-5">Sincronización de archivos (.lis) generados por el Ministerio</p>
        </div>

        @if (TempData["Exito"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show border-0 shadow-sm rounded-3 d-flex align-items-center p-3 mb-4" role="alert">
                <i class="bi bi-check-circle-fill fs-3 me-3 text-success"></i>
                <div class="fw-medium">@TempData["Exito"]</div>
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show border-0 shadow-sm rounded-3 d-flex align-items-center p-3 mb-4" role="alert">
                <i class="bi bi-shield-fill-exclamation fs-3 me-3 text-danger"></i>
                <div class="fw-medium">@TempData["Error"]</div>
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }

        <div class="card shadow-lg border-0 rounded-4 overflow-hidden">
            <div class="card-header bg-dark text-white p-3 border-0">
                <h6 class="mb-0 fw-bold tracking-wide"><i class="bi bi-file-earmark-binary-fill me-2"></i> MOTOR DE PROCESAMIENTO</h6>
            </div>
            <div class="card-body p-5">
                <form asp-controller="Administrador" asp-action="ProcesarArchivoLis" method="post" enctype="multipart/form-data" id="formUpload">

                    <div class="upload-zone text-center p-5 mb-4 border border-2 border-dashed border-primary rounded-3 bg-light transition-all" id="dropZone">
                        <i class="bi bi-file-earmark-text text-primary opacity-50 mb-3" style="font-size: 4rem;"></i>
                        <h5 class="fw-bold text-dark">Seleccione o arrastre su archivo aquí</h5>
                        <p class="text-muted small mb-4">Solo se admiten documentos de texto con formato .lis</p>

                        <div class="position-relative">
                            <input class="form-control form-control-lg bg-white shadow-sm" type="file" id="archivoLis" name="archivoLis" accept=".lis" required>
                        </div>
                    </div>

                    <div class="d-grid mt-4">
                        <button type="submit" class="btn btn-primary btn-lg fw-bold py-3 shadow-sm btn-subir" id="btnSubmit">
                            <i class="bi bi-cpu-fill me-2"></i> Procesar e Integrar a la Base de Datos
                        </button>
                    </div>
                </form>
            </div>
            <div class="card-footer bg-light border-top-0 text-center py-3">
                <small class="text-muted fw-semibold"><i class="bi bi-info-circle-fill me-1"></i> El sistema incluye escudo de seguridad anti-duplicados DNI/Periodo.</small>
            </div>
        </div>
    </div>
</div>