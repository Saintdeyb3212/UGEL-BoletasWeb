@{
    ViewData["Title"] = "Carga de Planilla LIS";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-primary text-white text-center">
                    <h4 class="mb-0"><i class="bi bi-cloud-arrow-up"></i> Carga Mensual de Boletas (.lis)</h4>
                </div>
                <div class="card-body p-4">

                    @if (TempData["Exito"] != null)
                    {
                        <div class="alert alert-success fw-bold">@TempData["Exito"]</div>
                    }
                    @if (TempData["Error"] != null)
                    {
                        <div class="alert alert-danger fw-bold">@TempData["Error"]</div>
                    }

                    <p class="text-muted text-center mb-4">
                        Seleccione el archivo plano (.lis) generado por el Ministerio para procesar y almacenar las boletas automáticamente.
                    </p>

                    <form asp-controller="Administrador" asp-action="ProcesarArchivoLis" method="post" enctype="multipart/form-data">
                        <div class="mb-4">
                            <label for="archivoLis" class="form-label fw-bold">Archivo de Planilla (.lis)</label>
                            <input class="form-control form-control-lg" type="file" id="archivoLis" name="archivoLis" accept=".lis" required>
                        </div>
                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-primary btn-lg">
                                Iniciar Procesamiento LIS
                            </button>
                        </div>
                    </form>

                </div>
            </div>
        </div>
    </div>
</div>